# ============================================================================
# UniFi Voucher Manager — runtime configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env` in the same directory and fill in the real values.
# The `.env` file is gitignored; this `.env.example` is a committed template.
# Docker Compose loads `.env` automatically via the `env_file` directive in
# compose.yaml.
# ============================================================================

# ---- UniFi controller (REQUIRED) -------------------------------------------

# URL of your UniFi controller, including protocol.
# Examples: https://unifi.example.com  |  https://192.168.8.1:443
UNIFI_CONTROLLER_URL=

# API key for your UniFi controller. Create under
# Settings → Control Plane → Integration.
UNIFI_API_KEY=

# Set to false ONLY if UNIFI_CONTROLLER_URL presents a self-signed cert
# (typical when connecting directly to the controller IP). If you reach it
# through a reverse proxy with a trusted cert, keep this as true.
UNIFI_HAS_VALID_CERT=true

# Site ID on the controller. "default" lets the backend auto-resolve it.
UNIFI_SITE_ID=default

# ---- Timezone & rolling vouchers -------------------------------------------

# IANA timezone for date formatting and the midnight cleanup job.
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Europe/Berlin

# Minutes a rolling voucher is valid after activation (default 480 = 8 h).
# ROLLING_VOUCHER_DURATION_MINUTES=480

# ---- Guest subnet restriction (OPTIONAL) -----------------------------------
# When set, clients from this subnet only get /welcome and the rolling-voucher
# endpoint; everything else returns 403. Leave empty to disable.
GUEST_SUBNETWORK=

# ---- WiFi QR code (OPTIONAL) -----------------------------------------------
# Required together to render the QR code on /kiosk and in the header.
WIFI_SSID=
WIFI_PASSWORD=
# WIFI_TYPE=WPA       # WPA | WEP | nopass (defaults to WPA if password set)
# WIFI_HIDDEN=false

# ---- Microsoft Entra ID authentication (REQUIRED) --------------------------
# Authentication guards `/`, `/print` and all `/rust-api/*` routes.

# Random string >= 32 chars. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Application (client) ID from the Entra ID app registration.
AUTH_MICROSOFT_ENTRA_ID_ID=

# Client secret VALUE (not the Secret ID!) from Certificates & secrets.
AUTH_MICROSOFT_ENTRA_ID_SECRET=

# Directory (tenant) ID from the app registration overview.
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=

# Object ID of the Entra ID group whose members are allowed to sign in.
# Users outside this group are rejected after Microsoft login.
ADMIN_GROUP_ID=

# Required when Next.js runs behind a reverse proxy so Auth.js trusts
# X-Forwarded-* headers. Keep as true for the default Docker deployment.
AUTH_TRUST_HOST=true

# Optional — set explicitly if AUTH_TRUST_HOST alone is insufficient, e.g.
# when the public URL differs significantly from what the container sees.
# AUTH_URL=https://uvm.example.com
